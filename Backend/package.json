{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r ./dist/Backend/src/instrumentation.js dist/Backend/src/server.js",
    "test": "npm run build && node --test --test-force-exit automated-tests/**/*.test.js",
    "test:unit": "npm run build && node --test --test-force-exit automated-tests/*.test.js",
    "test:integration": "npm run build && node --test --test-force-exit automated-tests/integration/*.test.js",
    "test:ci": "npm run build && npm run test",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:automated": "npm run test",
    "test:manual": "echo \"Run one or more manual test scripts from ./manual-tests\"",
    "test:download:prod": "node manual-tests/download-resume-production.test.js",
    "test:rate-limit": "node src/test.js",
    "test:rate-limit:login": "node manual-tests/rate-limit-login.test.js",
    "test:rate-limit:forgot-password": "node manual-tests/rate-limit-forgot-password.test.js",
    "test:cache:templates": "node manual-tests/cache-templates-hit.test.js",
    "dev": "ts-node -r ./src/instrumentation.ts src/server.ts",
    "migrate": "npm run build && ts-node scripts/migrate.ts",
    "migrate:up": "npm run build && ts-node scripts/migrate.ts up",
    "migrate:down": "npm run build && ts-node scripts/migrate.ts down",
    "backup": "bash scripts/backup.sh",
    "keep-alive": "node scripts/keep-alive.js",
    "start:with-keepalive": "node scripts/keep-alive.js & npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/instrumentation-mongodb": "^0.67.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.22.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^3.14.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "passport": "^0.7.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.43.0",
    "redis": "^5.8.3",
    "resend": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/redis-info": "^3.0.3",
    "@types/supertest": "^6.0.3",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
