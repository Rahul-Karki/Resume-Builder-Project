PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
CORS_ORIGIN=http://localhost:5173,https://your-frontend-domain.vercel.app
JWT_SECRET=your_jwt_secret_key
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
NODE_ENV=production
FRONTEND_URL=http://localhost:5173

REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
REDIS_CACHE_TTL_SECONDS=300
REDIS_RATE_LIMIT_WINDOW_MS=900000
REDIS_RATE_LIMIT_MAX=100

# Email Configuration
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Your App <onboarding@resend.dev>

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-backend-url.render.com/auth/google/callback
