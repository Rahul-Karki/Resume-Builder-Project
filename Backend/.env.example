## ─── Application Core ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
SERVICE_NAME=resume-builder-backend
SERVICE_VERSION=1.0.0

## ─── Database (MongoDB) ─────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

## ─── Frontend / CORS ────────────────────────────────────────────────────────────
# Primary frontend URL — must match exactly (protocol + host, no trailing slash)
FRONTEND_URL=https://your-frontend-domain.vercel.app
# Comma-separated additional allowed origins (exact match)
FRONTEND_URLS=https://your-frontend-domain.vercel.app,https://www.your-frontend-domain.vercel.app
# Allow localhost preview origins (http://localhost:*) for development.
# Set to true in dev/staging; keep false in production.
ALLOW_PREVIEW_ORIGINS=false
# Comma-separated regex patterns for additional allowed origins.
# Use for preview deployments with dynamic URLs. Example:
# CORS_EXTRA_PATTERNS=^https://my-app-.*\.vercel\.app$,^https://.*--my-app\.netlify\.app$
CORS_EXTRA_PATTERNS=

## ─── Authentication (JWT) ───────────────────────────────────────────────────────
# Symmetric keys (HS256 fallback) — 256-bit hex from CSPRNG
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_64_hex_char_access_secret
JWT_REFRESH_SECRET=your_64_hex_char_refresh_secret

# RSA keys (RS256) — takes priority when set. Single-line PEM with \n.
# Generate:
#   openssl genpkey -algorithm RSA -out private.pem
#   openssl rsa -pubout -in private.pem -out public.pem
# Then collapse to single line (Node will parse \n escapes):
#   (Get-Content public.pem -Raw) -replace "`r`n","\n" -replace "`n","\n"
# JWT_ACCESS_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...
# JWT_ACCESS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...
# JWT_REFRESH_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...
# JWT_REFRESH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...

# RSA key rotation — set old public key during rotation so tokens signed
# with the previous key still verify during the grace period.
# JWT_ACCESS_PUBLIC_KEY_OLD=-----BEGIN PUBLIC KEY-----\n...
# JWT_REFRESH_PUBLIC_KEY_OLD=-----BEGIN PUBLIC KEY-----\n...

## ─── Email ──────────────────────────────────────────────────────────────────────
# Provider: "brevo" (default, 300 free/day, no DNS required), "resend", or "console" (logs only)
EMAIL_PROVIDER=brevo
# Brevo — no DNS required, verify a single sender in dashboard
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM=noreply@yourdomain.com
# Resend — requires DNS records for custom domain (or use onboarding@resend.dev)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=Your App <noreply@example.com>

## ─── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_from_gcp
GOOGLE_CLIENT_SECRET=your_google_client_secret_from_gcp

## ─── Redis / Caching & Rate Limiting ────────────────────────────────────────────
# Native Redis URL (Docker/local Redis server)
# REDIS_URL=redis://localhost:6379/0

# Upstash Redis REST API (consumes free-tier quota; use instead of native Redis on Render)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Per-process soft cap on Upstash REST calls to stay within free-tier limits
# UPSTASH_CALLS_PER_MIN=600

# When true, skip Redis/Upstash entirely and use in-memory cache/rate-limiter
USE_MEMORY_ONLY_CACHE=false

REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_CACHE_TTL_SECONDS=300
REDIS_RATE_LIMIT_WINDOW_MS=900000
REDIS_RATE_LIMIT_MAX=100

## ─── Resume Download Queue ──────────────────────────────────────────────────────
# In-memory queue (no Redis/BullMQ); configure concurrency and retries here
RESUME_DOWNLOAD_JOB_ATTEMPTS=5
RESUME_DOWNLOAD_JOB_TIMEOUT_MS=120000
RESUME_DOWNLOAD_STALE_PENDING_MS=900000
RESUME_DOWNLOAD_WORKER_CONCURRENCY=2
RESUME_DOWNLOAD_BACKOFF_DELAY_MS=5000

## ─── AI / LLM Providers ─────────────────────────────────────────────────────────
# Provider selection: "openai" | "gemini" | "openrouter" | "auto"
AI_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenRouter (first-class provider, not a sub-type of OpenAI)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

AI_REQUEST_TIMEOUT_MS=12000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=30
AI_CREDITS_ENFORCED=false

## ─── Request Configuration ──────────────────────────────────────────────────────
REQUEST_BODY_LIMIT=1mb

## ─── Database Management ────────────────────────────────────────────────────────
CREATE_INDEXES_ON_STARTUP=true
INTEGRITY_CHECK_INTERVAL_MS=3600000

## ─── Observability & Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
ENABLE_METRICS=true
METRICS_PATH=/metrics

## ─── OpenTelemetry ──────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=resume-builder-backend
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-grafana-instance.example.com/otlp
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://your-grafana-instance.example.com/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://your-grafana-instance.example.com/v1/metrics
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer%20your_token
OTEL_INSTANCE_ID=your_grafana_loki_instance_id
OTLP_INSTANCE_ID=
OTEL_TRACES_SAMPLER_ARG=1
OTEL_METRIC_EXPORT_INTERVAL_MS=15000

## ─── Grafana (OTLP + Loki) ──────────────────────────────────────────────────────
GRAFANA_OTLP_ENDPOINT=https://your-grafana-instance.example.com/otlp
GRAFANA_API_TOKEN=your_grafana_api_token
GRAFANA_LOKI_URL=https://logs-prod-028.grafana.net/loki/api/v1/push
LOKI_INSTANCE_ID=your_loki_instance_id

## ─── Grafana Cloud Alert Rules (provisioned via API) ─────────────────────────
#
# To provision all alert rules defined in scripts/grafana-alerts.json:
#
#   1. Create a Service Account in Grafana Cloud:
#      Administration → Service accounts → "Alerting Provisioning" → Role: "Alerting Provisioning"
#   2. Copy the token (starts with glas_)
#   3. Run:
#      GRAFANA_STACK_URL=https://<your-stack>.grafana.net \
#      GRAFANA_SERVICE_ACCOUNT_TOKEN=glas_... \
#      SLACK_WEBHOOK_URL=https://hooks.slack.com/services/... \
#      PAGERDUTY_INTEGRATION_KEY=... \
#      npx ts-node scripts/provision-grafana-alerts.ts
#
#   4. To preview without making changes:
#      DRY_RUN=true ... npx ts-node scripts/provision-grafana-alerts.ts
#
GRAFANA_STACK_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=
# Grafana Cloud managed Prometheus datasource UID (usually "grafanacloud-prom")
GRAFANA_PROM_UID=grafanacloud-prom

# Rules that get created:
#
#   Rule                          | Metric                              | Threshold      | Severity
#   ──────────────────────────────┼─────────────────────────────────────┼────────────────┼─────────
#   High HTTP error rate          | rate(http_errors_total[5m])         | > 0.05         | critical
#   AI provider down              | absent(ai_requests_total)           | for 5m         | critical
#   High AI P95 latency           | histogram_quantile(0.95, ...)        | > 10000ms      | high
#   High token usage spike        | rate(ai_tokens_total[5m])           | > 100000       | high
#   Compliance violation          | rate(compliance_violations_total[5m])| > 0           | high
#   Orphaned documents threshold  | compliance_orphaned_documents       | > 100          | high
#   Low cache hit ratio           | cache_hits / (hits + misses)        | < 0.5          | medium
#   Frontend critical errors      | rate(frontend_metric_value_count[5m])| > 10          | medium
#
#   Rule                          | Metric                              | Threshold      | Channel
#   ──────────────────────────────┼─────────────────────────────────────┼────────────────┼────────
#   High error rate               | rate(http_errors_total[5m])         | > 0.05         | Slack
#   High AI latency               | histogram_quantile(0.95,            | > 10000ms      | Slack
#                                 |   rate(ai_request_duration_ms[5m])) |                |
#   AI provider down              | absent(ai_requests_total)           | for 5m         | Slack+PD
#   High token usage spike        | rate(ai_tokens_used_total[5m])      | > 100000       | Slack
#   Compliance violation spike    | rate(compliance_violations_total[5m])| > 0           | Slack+PD
#   Orphaned documents threshold  | compliance_orphaned_documents       | > 100          | Slack
#   Frontend critical errors      | rate(frontend_metric_value[5m])     | > 10           | Slack
#   Cache hit ratio low           | cache_hits_total / (cache_hits_total+| < 0.5         | Slack
#                                 |   cache_misses_total)               |                |
#
# Steps:
#   1. Go to Grafana Cloud → Alerts & IRM → Alert rules → New alert rule
#   2. Select "Grafana managed alert" → pick metric from the list
#   3. Set expression (e.g. `A > 0.05`), condition, duration
#   4. Add label `severity: critical|high|medium`, `team: backend`
#   5. Add contact point (Slack, PagerDuty, email from Grafana Cloud's Contact Points)
#   6. Repeat for each rule above
#   7. Use "Test rule" to verify the query returns data

## ─── Alerting (direct process.env, not in env schema) ───────────────────────────
# How to get a Slack webhook URL:
#   1. Go to https://api.slack.com/apps → Create New App → From scratch
#   2. Name it "Resume Builder Alerts", pick your workspace
#   3. Incoming Webhooks → Activate Incoming Webhooks → Add New Webhook to Workspace
#   4. Pick a channel (#ops, #alerts) → Copy the webhook URL
#   5. Paste below (raw URL, no wrapping):
SLACK_WEBHOOK_URL=
# Generic webhook (any HTTP endpoint that accepts POST JSON)
ALERT_WEBHOOK_URL=
# Email recipient for email alerts (uses Resend/Brevo via sendEmail utility)
ALERT_EMAIL_TO=
# PagerDuty Events API v2 integration key from service → Integrations → Events API v2
PAGERDUTY_INTEGRATION_KEY=

## ─── Keep Alive / Health Endpoint ───────────────────────────────────────────────
# ENABLE_KEEP_ALIVE=false
# BACKEND_URL=https://your-app.onrender.com
# BACKEND_PORT=5000
# BACKEND_HOST=0.0.0.0
# BACKEND_PROTOCOL=https
# SLA_TARGET=99.9

## ─── Storage (PDF files — optional, defaults to Mongo GridFS) ───────────────────
RESUME_DOWNLOAD_STORAGE_DIR=
RESUME_DOWNLOAD_PUBLIC_BASE_URL=
RESUME_DOWNLOAD_QUEUE_PREFIX=resume-builder
ATS_ANALYSIS_QUEUE_PREFIX=resume-builder-ats
ATS_ANALYSIS_JOB_ATTEMPTS=2
ATS_ANALYSIS_BACKOFF_DELAY_MS=3000

## ─── Puppeteer ──────────────────────────────────────────────────────────────────
# Path to Chromium executable (required on serverless/PaaS where Chromium isn't in PATH)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

## ─── Test Only ──────────────────────────────────────────────────────────────────
# TEST_PASSWORD=test-password-123
