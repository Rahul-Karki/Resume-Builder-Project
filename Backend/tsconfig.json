{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": "..",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*.ts", "../shared/src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__/**/*.ts",
    "src/__mocks__/**/*.ts",
    "tests"
  ]
}