        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "id": 9,
      "title": "Request Rate by Route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "description": "",
      "targets": [
        {
          "expr": "sum by (route) (rate(resume_builder_http_requests_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "id": 10,
      "title": "Latency (p95 by route)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "description": "",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(resume_builder_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Status Code Distribution",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "description": "",
      "targets": [
        {
          "expr": "sum by (status_code) (rate(resume_builder_http_requests_total[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "id": 12,
      "title": "Slowest Endpoints (p95 by route)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "description": "",
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(resume_builder_http_request_duration_seconds_bucket[5m]))))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "footer": {
          "show": true,
          "countRows": true
        },
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
