        "x": 0,
        "y": 8
      },
      "description": "",
      "targets": [
        {
          "expr": "sum by (name) (rate(resume_builder_frontend_metric_value_sum{name=~\"heap.*\"}[5m])) / sum by (name) (rate(resume_builder_frontend_metric_value_count{name=~\"heap.*\"}[5m]))",
          "legendFormat": "",
