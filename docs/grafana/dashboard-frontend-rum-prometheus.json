        "h": 5,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "description": "",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(resume_builder_frontend_metric_value_bucket{name=\"spa_navigation\"}[5m])))",
