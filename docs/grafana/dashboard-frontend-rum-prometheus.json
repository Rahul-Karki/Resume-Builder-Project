        "y": 3
      },
      "description": "",
      "targets": [
        {
          "expr": "histogram_quantile(0.75, sum by (le) (rate(resume_builder_frontend_metric_value_bucket{name=\"LCP\"}[5m])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "legend": {
