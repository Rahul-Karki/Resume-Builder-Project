      "description": "",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(resume_builder_frontend_metric_value_bucket{name=~\"api_.*\"}[5m])) by (le))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
