        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 3
      },
      "description": "",
      "targets": [
        {
          "expr": "histogram_quantile(0.75, sum by (le) (rate(resume_builder_frontend_metric_value_bucket{name=\"FID\"}[5m])))",
