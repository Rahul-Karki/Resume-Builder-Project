{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus (Grafana Cloud or self-hosted)",
      "description": "Select the Prometheus data source that contains your OTel metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "6.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "title": "Resume Builder — Production Observability (/metrics)",
  "description": "Comprehensive dashboard covering HTTP, AI, Queue, Redis, DB, Email, Business KPIs, Frontend, and System health. All metrics are dual-written OTel or Prometheus.",
  "tags": [
    "resume-builder",
    "observability",
    "production"
  ],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ],
    "time_options": [
      "5m",
      "15m",
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d",
      "30d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "query": "production,staging,development",
        "includeAll": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Service Health",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 1,
      "title": "Service Up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "value": "null",
              "text": "DOWN",
              "color": "red"
            },
            {
              "type": "range",
              "from": 0,
              "to": 0,
              "text": "DOWN",
              "color": "red"
            },
            {
              "type": "range",
              "from": 1,
              "to": 999,
              "text": "UP",
              "color": "green"
            }
          ],
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(resume_builder_http_requests_total[1m])) > 0",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "description": "Detects if the service is receiving traffic. Green = UP, Red = DOWN"
    },
    {
      "id": 2,
      "title": "Error Rate (5xx / total)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "sum(rate(resume_builder_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(resume_builder_http_requests_total[5m]))",
          "legendFormat": "Error Ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "resume_builder_http_requests_total",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Usage (per core)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 60
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "cpu_percent",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Event Loop Lag",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "event_loop_lag_ms",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory (Node process)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 314572800
              },
              {
                "color": "red",
                "value": 524288000
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "resume_builder_process_resident_memory_bytes or resume_builder_process_resident_memory_bytes",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "description": "Node process resident memory. Thresholds: 300MB yellow, 500MB red."
    },
    {
      "id": 7,
      "title": "Request Rate (all routes)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "stacking": {
              "mode": "none"
            },
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(resume_builder_http_requests_total[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP & API Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 8,
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(resume_builder_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(resume_builder_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(resume_builder_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "title": "Request Size Distribution",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(by (le, method, route) (rate(resume_builder_http_request_size_bytes_bucket[5m]))) by (le))",
          "legendFormat": "p95 size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "HTTP Status Code Rate (4xx / 5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "sum"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum(rate(resume_builder_http_requests_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(resume_builder_http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "type": "row",
      "title": "AI Service",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      }
    },
    {
      "id": 11,
      "title": "AI Requests by Provider & Status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 13
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum by (provider, status) (rate(resume_builder_ai_requests_total[5m]))",
          "legendFormat": "{{provider}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "AI Latency by Provider (p95)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(resume_builder_ai_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "AI Cost (USD) — 24h",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 16,
        "y": 13
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "targets": [
        {
          "expr": "sum(increase(resume_builder_ai_cost_total[24h]))",
          "legendFormat": "Cost",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Token Usage Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 20,
        "y": 13
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum by (token_type) (rate(resume_builder_ai_tokens_used_total[5m]))",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "title": "AI Provider Errors",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "transformations": [],
      "options": {
        "footer": {
          "show": true,
          "countRows": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "auto"
          }
        }
      },
      "targets": [
        {
          "expr": "sort_desc(sum by (provider, error_category) (increase(resume_builder_ai_provider_errors_total[1h])))",
          "legendFormat": "{{provider}} — {{error_category}}",
          "format": "table",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 16,
      "title": "Hallucination Detection Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineInterpolation": "smooth"
          },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum(rate(resume_builder_ai_hallucination_detected_total[5m]))",
          "legendFormat": "Hallucinations/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(resume_builder_ai_hallucination_detected_total[5m])) / sum(rate(resume_builder_ai_requests_total{status=\"success\"}[5m]))",
          "legendFormat": "Rate vs success",
          "refId": "B"
        }
      ]
    },
    {
      "id": 17,
      "title": "AI Fallback Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 19
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineInterpolation": "stepAfter"
          },
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "resume_builder_ai_fallback_rate",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Queue & Background Jobs",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 18,
      "title": "Queue Depth (current)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 26
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 20
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(resume_builder_queue_depth) by (queue)",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "title": "Jobs Processed Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 7,
        "x": 3,
        "y": 26
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          },
