        }
      }
    },
    {
      "id": 6,
      "title": "Disk Write (ops/s)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "description": "",
      "targets": [
        {
          "expr": "disk_write_ops_per_second",
