      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "description": "",
      "targets": [
        {
          "expr": "gc_duration_ms",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "id": 11,
      "title": "Memory Timeline",
