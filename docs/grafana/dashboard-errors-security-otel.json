        "x": 21,
        "y": 0
      },
      "description": "",
      "targets": [
        {
          "expr": "increase(http_requests_total{status_code=\"401\"}[1h])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
