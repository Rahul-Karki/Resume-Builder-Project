      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 13
      },
      "description": "",
      "targets": [
        {
          "expr": "rate(user_signups_total[5m]) OR rate(user_login_failures_total[5m])",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
