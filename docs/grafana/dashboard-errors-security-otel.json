    {
      "id": 14,
      "title": "Recent Suspicious Events",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "description": "",
      "targets": [
        {
          "expr": "sort_desc(sum by (type) (increase(suspicious_activities_total[1h])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "footer": {
          "show": true,
          "countRows": true
        },
        "legend": {
          "showAt": "right",
