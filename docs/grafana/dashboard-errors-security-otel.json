          ],
          "values": false
        },
        "textMode": "auto",
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
      "id": 8,
      "title": "4xx by Route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 3
      },
      "description": "",
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{status_code=~\"4..\"}[5m]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "stacking": {
              "mode": "normal"
            },
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": {
          "showAt": "right",
          "calcs": [
            "max"
          ]
        }
      }
    },
    {
