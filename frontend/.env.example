# Frontend Environment Variables
# Copy this file to .env.local and customize for your environment
# Note: In Vite, only variables prefixed with VITE_ are exposed to client code

# Application URLs
VITE_BASE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:5000/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Error Tracking (Sentry)
# Get your DSN from https://sentry.io/organizations/YOUR_ORG/projects/YOUR_PROJECT/keys/
# Only required for production error tracking; optional for development
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
